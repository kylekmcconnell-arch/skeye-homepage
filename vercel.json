{
  "rewrites": [
    {
      "source": "/app",
      "destination": "https://skeye-app.vercel.app/app"
    },
    {
      "source": "/app/",
      "destination": "https://skeye-app.vercel.app/app"
    },
    {
      "source": "/app/:path*",
      "destination": "https://skeye-app.vercel.app/app/:path*"
    }
  ]
}
